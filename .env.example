# ============================================================
# Brigade Electronics — Vehicle Onboarding (Lean Edition)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- DVLA Vehicle Enquiry API (optional but recommended for UK vehicles) ---
# Request a key at: https://developer-portal.driver-vehicle-licensing.api.gov.uk/
# If not set, the app falls back to the public NHTSA VIN decoder.
DVLA_API_KEY=your_dvla_api_key_here

# Server
PORT=3000
NODE_ENV=production

# Where uploaded photos and PDFs are stored (relative to project root)
UPLOADS_DIR=uploads

# Where the SQLite database file is stored
DATA_DIR=data

# --- Email (SendGrid — HTTPS API, works on Railway free tier) ---
# Sign up at app.sendgrid.com, create an API key with "Mail Send" permission.
# Verify your sender address/domain under Settings → Sender Authentication.
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM=onboarding@brigade-halo.com

# Always-CC recipients (comma-separated)
EMAIL_RECIPIENTS=joel.jijo@brigade-halo.com

# --- Admin page ---
# Simple password to access /admin — change this to something strong
ADMIN_PASSWORD=change_me_now

